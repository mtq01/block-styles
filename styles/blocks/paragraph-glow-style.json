{
  "version": 3,
  "title": "Glow",
  "blockTypes": ["core/paragraph"],
  "styles": {
"color": {
      "background": "var(--wp--preset--color--glow-base)",
      "text": "var(--wp--preset--color--p-text)"
    },
    "border": {
        "radius": "1rem"
    },
    "spacing": {
        "padding": "var(--wp--preset--spacing--large)"
    },
    "typography": {
      "fontSize": "1.2rem",
      "lineHeight": "1.5",
      "fontStyle": "normal",
      "fontWeight": "600",
      "letterSpacing": "1px",
      "textTransform": "uppercase"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--p-text)"
        },
        ":hover": {
          "color": { 
            "text": "var(--wp--preset--color--a-hover)"
          }
        }
      }
    }
  }
}