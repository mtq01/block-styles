{
  "$schema": "https://schemas.wp.org/wp/6.9/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        {
          "color": "#202020",
          "name": "Glow Base",
          "slug": "glow-base"
        },
        {
          "color": "#05FC70",
          "name": "Glow Color",
          "slug": "glow-color"
        },
        {
        "color": "#00ffff",
        "name": "Button Glow",
        "slug": "btn-glow"
        },
        {
          "slug": "btn-primary",
          "color": "#0073e6",
          "name": "Primary Button"
        },
        {
          "slug": "btn-text",
          "color": "#ffffff",
          "name": "Button Text"
        },
        {
          "slug": "btn-primary-hover",
          "color": "#005bb5",
          "name": "Button Primary Hover"
        },
        {
          "slug": "table-bg",
          "color": "#ffffff",
          "name": "Table Background"
        },
        {
          "slug": "table-text",
          "color": "#000000",
          "name": "Table Text"
        },
        {
          "slug": "table-row-hover",
          "color": "#00c8ff", 
          "name": "Table Row Hover"
        },
        {
          "color": "#ffffff",
          "name": "White",
          "slug": "p-text"
        },

        {
          "color": "#05104f",
          "name": "Arctic Base",
          "slug": "arctic-base"
        },
        {
          "color": "#89d4e8",
          "name": "Arctic Color",
          "slug": "arctic-color"

        },
        {
          "color": "#edf6f7",
          "name": "Ice",
          "slug": "arctic-text"
        }
      ]
    },
    "layout": {
      "contentSize": "620px",
      "wideSize": "1000px"
    },
    "spacing": {
      "spacingSizes": [
        {
          "name": "Small",
          "size": "1rem",
          "slug": "small"
        },
        {
          "name": "Medium",
          "size": "1.25rem",
          "slug": "medium"
        },
        {
          "name": "Large",
          "size": "2rem",
          "slug": "large"
        },
        {
          "name": "X-Large",
          "size": "3rem",
          "slug": "x-large"
        }
      ],
      "units": ["%", "px", "em", "rem", "vh", "vw"]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
          "name": "System Font",
          "slug": "system-font"
        }
      ]
    },
    "useRootPaddingAwareAlignments": true
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header"
    },
    {
      "area": "footer",
      "name": "footer"
    }
  ]
}
